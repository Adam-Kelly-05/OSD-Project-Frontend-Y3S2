{
  "name": "web-project-y3-s1-front-end",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run format && ng serve",
    "dev": "npm run format && ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.2.2",
    "@angular/cdk": "20.2.2",
    "@angular/common": "20.2.2",
    "@angular/compiler": "20.2.2",
    "@angular/core": "20.2.2",
    "@angular/forms": "20.2.2",
    "@angular/material": "20.2.2",
    "@angular/platform-browser": "20.2.2",
    "@angular/platform-browser-dynamic": "20.2.2",
    "@angular/router": "20.2.2",
    "angular-auth-oidc-client": "20.0.3",
    "bootstrap": "^5.3.8",
    "leaflet": "^1.9.4",
    "profane-words": "^2.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "20.2.2",
    "@angular/cli": "20.2.2",
    "@angular/compiler-cli": "20.2.2",
    "@angular/localize": "20.2.2",
    "@playwright/test": "^1.58.2",
    "@types/jasmine": "~5.1.0",
    "@types/leaflet": "^1.9.21",
    "baseline-browser-mapping": "^2.9.19",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.2",
    "typescript": "~5.9.2"
  }
}
